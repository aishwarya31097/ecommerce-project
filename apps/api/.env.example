# Copy to .env in this folder. Prisma and Nest read from apps/api when you run commands from the monorepo root with pnpm --filter api.

# MySQL (match docker-compose defaults or your own instance)
DATABASE_URL="mysql://root:devpassword@localhost:3307/ecommerce"

# API
PORT=3001

# Optional: comma-separated origins for the Next.js app (default: localhost:3000)
# CORS_ORIGINS=http://localhost:3000,http://localhost:3002
JWT_SECRET=change-me-in-production