{
  "extends": "@repo/typescript-config/nestjs.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"]
    },
    "sourceMap": true,
    "declaration": true,
    "removeComments": true,
    "incremental": true
  },
 "include": ["src/**/*.ts", "test/**/*.ts"],
"exclude": ["node_modules", "dist"]
}